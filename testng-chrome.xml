<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Chrome Suite" verbose="1" parallel="classes" thread-count="2">
    <parameter name="browser" value="chrome"/>

    <listeners>
        <listener class-name="com.ui.automation.framework.listeners.TestListener"/>
    </listeners>

    <test name="Regression On Chrome">

        <classes>
            <class name="com.ui.automation.framework.tests.AuthenticationTests"/>
            <class name="com.ui.automation.framework.tests.ContactAndReviewTests"/>
            <class name="com.ui.automation.framework.tests.ProductCatalogTests"/>
            <class name="com.ui.automation.framework.tests.SubscriptionTests"/>
            <class name="com.ui.automation.framework.tests.CartManagementTests"/>
            <class name="com.ui.automation.framework.tests.CheckoutPlacementTests"/>
            <class name="com.ui.automation.framework.tests.CheckoutValidationTests"/>
            <class name="com.ui.automation.framework.tests.HomePageUiTests"/>
        </classes>

    </test>
</suite>